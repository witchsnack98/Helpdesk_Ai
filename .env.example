# ─── DATABASE ───────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/helpdesk_ai?schema=public"

# ─── AUTH ───────────────────────────────────────────
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AI ─────────────────────────────────────────────
AI_PROVIDER="gemini"                  # "gemini" | "openai"
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"  # optional if using Gemini

# ─── FILE STORAGE (Supabase Storage) ────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-key"
SUPABASE_BUCKET="helpdesk-attachments"

# ─── BACKEND ────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ─── FRONTEND (Next.js) ─────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
